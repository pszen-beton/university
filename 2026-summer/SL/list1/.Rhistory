columns = 1:4,
mapping = aes(alpha = 0.5),
upper = list(continuous = wrap("cor", size = 3, color = 'steelblue')),
lower = list(continuous = wrap("points", size = 0.8)),
diag = list(continuous = wrap("densityDiag"))) +
theme_bw()
